REDDIT_CLIENT_ID=CHANGE_ME
REDDIT_CLIENT_SECRET=CHANGE_ME
REDDIT_USER_AGENT=memelensBot/1.0
SUBREDDIT=memes
TIME_FILTER=year
LIMIT=1000

QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=CHANGE_ME
QDRANT_COLLECTION=memelens

TL_API_KEY=CHANGE_ME
TL_MODEL=marengo3.0

MISTRAL_API_KEY=CHANGE_ME
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_EMBED_MODEL=mistral-embed

NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
