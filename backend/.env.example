NEO4J_DATABASE=your-instance-id
AURA_INSTANCEID=your-instance-id
AURA_INSTANCENAME=Instance01

COGNEE_LLM_API_KEY=

DATA_DIR=./data
PUBLIC_IMAGE_BASE=http://localhost:8000/static/images
S3_ENDPOINT=
S3_REGION=ap-southeast-1
